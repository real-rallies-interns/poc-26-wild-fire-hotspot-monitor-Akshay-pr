# ── Wildfire Hotspot Monitor — Backend Environment Template ────────────────────
# Copy this file to .env and replace placeholders with your actual keys.

# NASA FIRMS MAPS API configuration
# Get your free API key at: https://firms.modaps.eosdis.nasa.gov/api/config/
NASA_API_KEY=your_nasa_api_key_here

# NASA FIRMS public MODIS C6.1 global 7-day CSV feed (Fallback)
NASA_FIRMS_URL=https://firms.modaps.eosdis.nasa.gov/active_fire/c6.1/csv/MODIS_C6_1_Global_7d.csv

# How long (seconds) to cache the hotspot response before re-fetching NASA
CACHE_TTL_SECONDS=300

# Port the uvicorn server listens on
BACKEND_PORT=8000

# Origin of the Next.js frontend (used for CORS allow_origins)
FRONTEND_ORIGIN=http://localhost:3000
