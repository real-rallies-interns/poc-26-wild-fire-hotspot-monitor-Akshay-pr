# ── Wildfire Hotspot Monitor — Backend Environment ────────────────────────────
# Copy this file to .env and adjust values as needed.
# All variables have sensible defaults inside main.py.

# NASA FIRMS public MODIS C6.1 global 7-day CSV feed
NASA_FIRMS_URL=https://firms.modaps.eosdis.nasa.gov/active_fire/c6.1/csv/MODIS_C6_1_Global_7d.csv

# How long (seconds) to cache the hotspot response before re-fetching NASA
CACHE_TTL_SECONDS=300

# Port the uvicorn server listens on
BACKEND_PORT=8000

# Origin of the Next.js frontend (used for CORS allow_origins)
FRONTEND_ORIGIN=http://localhost:3000
